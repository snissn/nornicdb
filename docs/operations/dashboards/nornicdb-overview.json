  "schemaVersion": 39,
  "tags": ["nornicdb", "graph-database"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(nornicdb_build_info, instance)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "NornicDB Overview",
  "uid": "nornicdb-overview",
  "version": 1
