        {
          "expr": "nornicdb_storage_nodes_total",
          "legendFormat": "nodes"
        },
        {
          "expr": "nornicdb_storage_edges_total",
          "legendFormat": "edges"
        }
      ]
    },
    {
      "title": "MVCC Readers & Pressure",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "targets": [
        {
          "expr": "nornicdb_mvcc_active_readers",
          "legendFormat": "active readers"
        },
        {
          "expr": "nornicdb_mvcc_pressure_band",
          "legendFormat": "pressure band"
        }
      ]
    },
    {
      "title": "MVCC Oldest Reader Age",
