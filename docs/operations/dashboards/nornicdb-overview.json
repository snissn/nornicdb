      "targets": [
        {
          "expr": "nornicdb_replication_lag_entries",
          "legendFormat": "lag entries {{instance}}"
        },
        {
          "expr": "nornicdb_replication_lag_bytes",
          "legendFormat": "lag bytes {{instance}}"
        }
      ]
    },
    {
      "title": "Replication RTT & Role",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 44},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_replication_rtt_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 RTT"
        }
      ]
    },
    {
      "title": "Search Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 52},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_search_requests_total[5m])) by (mode, result)",
          "legendFormat": "{{mode}} {{result}}"
        }
      ]
    },
    {
      "title": "Search Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 52},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_search_duration_seconds_bucket[5m])) by (le, mode))",
          "legendFormat": "p99 {{mode}}"
        }
      ]
    },
    {
      "title": "Embedding Processing",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 60},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_embed_processed_total[5m])) by (mode)",
          "legendFormat": "{{mode}}/s"
        },
        {
          "expr": "nornicdb_embed_queue_depth",
          "legendFormat": "queue depth"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 60},
      "targets": [
        {
          "expr": "nornicdb_cache_hit_ratio",
          "legendFormat": "{{cache}} hit ratio"
        }
      ]
    },
    {
      "title": "OTel BSP Health",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 68},
      "targets": [
        {
          "expr": "nornicdb_otel_bsp_queue_depth",
          "legendFormat": "queue depth"
        },
        {
          "expr": "rate(nornicdb_otel_bsp_dropped_spans_total[5m])",
          "legendFormat": "dropped/s"
        }
      ]
    },
    {
      "title": "Auth Attempts",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 68},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_auth_attempts_total[5m])) by (result, protocol)",
          "legendFormat": "{{protocol}} {{result}}"
        }
      ]
    }
