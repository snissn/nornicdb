{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_http_requests_total[5m])) by (method, route, status)",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ]
    },
    {
      "title": "HTTP Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p99 {{route}}"
        }
      ]
    },
    {
      "title": "Bolt Connections Active",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "nornicdb_bolt_connections_active",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Bolt Message Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_bolt_messages_total[5m])) by (op, result)",
          "legendFormat": "{{op}} {{result}}"
        }
      ]
    },
    {
      "title": "Bolt Message Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_bolt_message_duration_seconds_bucket[5m])) by (le, op))",
          "legendFormat": "p99 {{op}}"
        }
      ]
    },
    {
      "title": "Cypher Query Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_cypher_queries_total[5m])) by (op_type, result)",
          "legendFormat": "{{op_type}} {{result}}"
        }
      ]
    },
    {
      "title": "Cypher Query Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_cypher_query_duration_seconds_bucket[5m])) by (le, op_type))",
          "legendFormat": "p99 {{op_type}}"
        }
      ]
    },
    {
      "title": "Active Transactions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "nornicdb_cypher_active_transactions",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Slow Queries",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "targets": [
        {
          "expr": "sum(rate(nornicdb_cypher_slow_queries_total[5m]))",
          "legendFormat": "slow/s"
        }
      ]
    },
    {
      "title": "Storage Operations",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nornicdb_storage_op_duration_seconds_bucket[5m])) by (le, op))",
          "legendFormat": "p99 {{op}}"
        }
      ]
    },
    {
      "title": "Storage Size",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {
          "expr": "nornicdb_storage_bytes",
